# CCP-Adapter Configuration
# Copy this file to .env and fill in your actual values

# Hostname for the application
APP_DOMAIN=localhost

# FHIR Server Configuration
# URL of your FHIR server endpoint
FHIR_SERVER_URL=https://your-fhir-server.example.com/fhir
# Username for FHIR server authentication
FHIR_USERNAME=your-fhir-username
# Password for FHIR server authentication
FHIR_PASSWORD=your-fhir-password

# ICD-10 Filter (optional)
# Leave empty to include all patients, or set to specific ICD-10 code (e.g., C44.3)
ICD10_FILTER=

# Express Server Configuration
VITE_EXPRESS_BASEURL=http://localhost:8251/
# Username for Express basic authentication
VITE_EXPRESS_USERNAME=your-express-username
# Password for Express basic authentication
VITE_EXPRESS_PASSWORT=your-express-password

# Port Configuration
KEYCLOAK_PORT=8252
EXPRESS_PORT=8251
PORT=5000

# Application URLs
APP_URL_CLIENT=http://localhost:3000/
APP_URL_API=http://localhost:8080/

# Basic Authentication
# Username for basic HTTP authentication
BASIC_AUTH_USERNAME=your-basic-auth-username
# Password for basic HTTP authentication
BASIC_AUTH_PASSWORD=your-basic-auth-password

# Keycloak Configuration
KEYCLOAK_URL=http://keycloak:8080/
KEYCLOAK_REALM=ovis
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
# Secret for Keycloak admin client
KEYCLOAK_ADMIN_CLIENT_SECRET=your-keycloak-admin-client-secret
KEYCLOAK_CLIENT_ID=ovis_client
# Secret for OVIS client in Keycloak
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret
