# ========================================
# OVIS CONFIGURATION
# ========================================
# This file contains example configuration for the OVIS application.
# Copy this file to .env and customize the values for your environment.
# Variables are organized by function for easy management.
# ========================================

# ========================================
# CORE SETTINGS - Most commonly changed
# ========================================
# The domain/hostname where the application is hosted (use APP_DOMAIN to avoid Docker hostname truncation)
APP_DOMAIN=localhost

# Data Import Mode: demo, ccp, or onkostar
# NOTE: Must be lowercase (Docker image naming requirement)
# demo: Use demo data (recommended for initial setup and testing)
# ccp: Use Clinical Cancer Profile data (requires external data source)
# onkostar: Use ONKOSTAR data (requires database configuration)
OVIS_IMPORT_MODE=demo

# Enable/disable login functionality
PUBLIC_LOGIN_ENABLED=false

# Optional frontend base path (empty = root deployment).
# Example for reverse-proxy subpath deployment: /ccp-ovis
OVIS_PUBLIC_BASE_PATH=

# ========================================
# PROXY CONFIGURATION (Optional)
# ========================================
# Use these only if your server must access the internet through a corporate proxy.
# Leave all three variables empty when no proxy is required.
#
# Typical values:
# OVIS_HTTP_PROXY=http://proxy.example.org:8080
# OVIS_HTTPS_PROXY=http://proxy.example.org:8080
# OVIS_NO_PROXY=localhost,127.0.0.1,::1,keycloak,keycloak-config,postgres,nginx,express-auth,ovis-frontend,ovis-frontend-dev,ovis-backend-apollo,ovis-backend-database-mongodb,ovis-backend-mongodb-data-preprocessing,ovis-backend-data-import,mongodb-restore,mongodb-backup,.example.org,.internal.example,.svc,.cluster.local
OVIS_HTTP_PROXY=
OVIS_HTTPS_PROXY=
OVIS_NO_PROXY=

# ========================================
# IMAGE PUBLISHING (Standalone / General)
# ========================================
# This branch publishes the full standalone image set used by compose-image.yaml.
# The `OVIS_IMPORT_MODE` value from the core settings above selects the
# standalone frontend flavor; all importer images (demo, ccp, onkostar) are
# published in every run.
OVIS_IMAGE_TAG=latest
# Build all import flavor images (DEMO, CCP, ONKOSTAR) in one publish run.
OVIS_IMAGE_BUILD_ALL_IMPORT_IMAGES=true
# Buildx platforms used during image publishing.
OVIS_IMAGE_BUILD_PLATFORMS=linux/amd64,linux/arm64
# Retries for transient build/push failures.
OVIS_IMAGE_MAX_RETRIES=2

# General target registry - all standalone images go here.
# The shared Docker Hub namespace for this repo is `thewindmom`.
# Examples:
#   Docker Hub: your-dockerhub-username
#   GHCR:       ghcr.io/your-org/ovis
#   Custom:     registry.example.com/namespace
OVIS_GENERAL_IMAGE_NAMESPACE=thewindmom
OVIS_GENERAL_IMAGE_REGISTRY_USERNAME=
OVIS_GENERAL_IMAGE_REGISTRY_PASSWORD=

# ========================================
# SITE CONFIGURATION PATHS (Image-ready)
# ========================================
# Root folder for site-specific runtime files (certificates, downloads, backups, etc.)
# Defaults to repository paths for backward compatibility; override for image-only deployments.
OVIS_SITE_CONFIG_DIR=.

# Optional explicit path overrides (leave empty to derive from OVIS_SITE_CONFIG_DIR):
# - User-facing PDFs served under /downloads
OVIS_SITE_DOWNLOADS_DIR=
# - TLS certificates and LDAP trust certs
OVIS_SITE_CERTS_DIR=
# - Keycloak base realm JSON (defaults to repo path for first-run reliability)
OVIS_SITE_KEYCLOAK_REALM_FILE=./Backend/Authentication/Keycloak/ovis-realm.json
# - Optional site-provided import payload file (omock.json)
OVIS_SITE_OMOCK_FILE=/dev/null

# ========================================
# MONGODB SNAPSHOT BACKUPS
# ========================================
# Interval in seconds between automated Mongo dumps (21600 = 6 hours)
MONGO_BACKUP_INTERVAL_SECONDS=10
# Keep only the most recent N snapshots (0 disables pruning)
MONGO_BACKUP_RETENTION=3
# Databases included in backup/restore cycles (comma-separated)
MONGO_BACKUP_DBS=onc_test
# Collections synchronized from each database (comma-separated)
MONGO_BACKUP_COLLECTIONS=user
# During restore, treat these _id values as seed records and ignore them when checking if data already exists
MONGO_RESTORE_IGNORE_IDS=ovis-root

# ========================================
# SERVICE PORTS
# ========================================
# Port numbers for each service when accessed directly (not through nginx)
FRONTEND_PORT=5173
APOLLO_PORT=4001
CREDOS_PORT=4000
EXPRESS_PORT=8251
KEYCLOAK_PORT=8252

# ========================================
# AUTHENTICATION
# ========================================
# Express API Authentication
# These credentials are used by the frontend to authenticate to the Express API
# Use strong, unique passwords in production
EXPRESS_AUTH_USERNAME=your-express-username
EXPRESS_AUTH_PASSWORD=your-express-password

# Keycloak Admin Credentials
# Use strong, unique passwords in production
KEYCLOAK_ADMIN=your-keycloak-admin
KEYCLOAK_ADMIN_PASSWORD=your-keycloak-admin-password

# Default OVIS application root user credentials
OVIS_ROOT_USERNAME=ovis-root
OVIS_ROOT_PASSWORD=your-ovis-root-password

# Keycloak Client Configuration
KEYCLOAK_REALM=ovis
KEYCLOAK_CLIENT_ID=ovis_client
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=your-keycloak-admin-client-secret

# ========================================
# LDAP CONFIGURATION (Optional)
# ========================================
# Enable LDAP authentication integration
# When PUBLIC_LDAP_ENABLED=true, all LDAP parameters below must be configured
# Leave PUBLIC_LDAP_ENABLED empty or false to use local Keycloak authentication only
PUBLIC_LDAP_ENABLED=false

# LDAP Connection Settings
# Example: ldaps://ldap.example.org:636
LDAP_CONNECTION_URL=ldaps://your-ldap-server.example.com:636

# LDAP Bind Credentials
# The DN of the LDAP user that Keycloak will use to access the LDAP server
# Example: cn=svc-ldap,ou=ServiceAccounts,dc=example,dc=org
LDAP_BIND_DN=cn=your-bind-user,ou=ServiceAccounts,dc=your-domain,dc=com

# Password for the LDAP bind user
LDAP_BIND_CREDENTIAL=your-ldap-password

# LDAP User Search Base
# The DN where user searches will start in the LDAP tree
# Keycloak UI: LDAP searching and updating > Users DN
# Example: dc=example,dc=org
LDAP_USERS_DN=ou=Users,dc=example,dc=org

# LDAP Edit Mode
# Keycloak UI: LDAP searching and updating > Edit mode
# READ_ONLY: Users are read from LDAP only (recommended for Active Directory)
# WRITABLE: Keycloak can write back to LDAP
LDAP_EDIT_MODE=READ_ONLY

# LDAP Vendor
# Keycloak UI: Connection and authentication settings > Vendor
# Common values: ad (Active Directory), other (generic LDAP), rhds
LDAP_VENDOR=ad

# LDAP Username Attribute
# Keycloak UI: LDAP searching and updating > Username LDAP attribute
# Also used for the Username mapper > LDAP Attribute to keep provider and mapper aligned.
# Common values: cn, sAMAccountName, uid
LDAP_USERNAME_ATTRIBUTE=sAMAccountName

# LDAP RDN Attribute
# Keycloak UI: LDAP searching and updating > RDN LDAP attribute
# Often the same as LDAP_USERNAME_ATTRIBUTE. For AD, cn is common even when username uses sAMAccountName.
LDAP_RDN_ATTRIBUTE=sAMAccountName

# LDAP UUID Attribute
# Keycloak UI: LDAP searching and updating > UUID LDAP attribute
# Common values: objectGUID (AD), entryUUID (OpenLDAP)
LDAP_UUID_ATTRIBUTE=objectGUID

# LDAP User Object Classes
# Keycloak UI: LDAP searching and updating > User object classes
# Comma-separated list exactly as Keycloak expects it.
LDAP_USER_OBJECT_CLASSES=person, organizationalPerson, user

# Additional LDAP User Filter (optional)
# Keycloak UI: LDAP searching and updating > User LDAP filter
# Leave empty if you want Keycloak to search all users under LDAP_USERS_DN.
LDAP_USER_FILTER=

# LDAP Search Scope (optional)
# Keycloak UI: LDAP searching and updating > Search scope
# Use 1 for One Level, 2 for Subtree.
LDAP_SEARCH_SCOPE=2

# LDAP Read Timeout in milliseconds (optional)
# Keycloak UI: LDAP searching and updating > Read timeout
LDAP_READ_TIMEOUT=

# LDAP Pagination (optional)
# Keycloak UI: LDAP searching and updating > Pagination
# Use true if your directory requires paged search results.
LDAP_PAGINATION=false

# LDAP Referral Handling (optional)
# Keycloak UI: LDAP searching and updating > Referral
# Common values: ignore, follow
LDAP_REFERRAL=ignore

# LDAP attribute mapped to Keycloak email (optional)
# Keycloak UI: Mappers > email > LDAP Attribute
LDAP_EMAIL_ATTRIBUTE=mail

# LDAP attribute mapped to Keycloak first name (optional)
# Keycloak UI: Mappers > first name > LDAP Attribute
LDAP_FIRST_NAME_ATTRIBUTE=givenName

# LDAP attribute mapped to Keycloak last name (optional)
# Keycloak UI: Mappers > last name > LDAP Attribute
LDAP_LAST_NAME_ATTRIBUTE=sn

# LDAP SSL Certificate
# Name of the certificate file in Setup/Certificates/ for LDAPS connections.
# PEM-encoded certificates are expected; filename extension can be .pem or .crt.
# Examples: lmu.pem or lmu.crt
LDAP_CERTIFICATE_NAME=your-certificate.pem

# ========================================
# DATABASE CONFIGURATION
# ========================================
# MongoDB Configuration
DB=onc_test
MONGO_VER=latest

KEYCLOAK_PRESERVE_REALM=true
# PostgreSQL Backup Configuration
POSTGRES_BACKUP_HOST=postgres
POSTGRES_BACKUP_PORT=5432
POSTGRES_BACKUP_DB=keycloak
POSTGRES_BACKUP_USER=your-postgres-username
POSTGRES_BACKUP_PASSWORD=your-postgres-password
POSTGRES_BACKUP_INTERVAL_SECONDS=20
POSTGRES_BACKUP_RETENTION=3
# PostgreSQL Configuration (for Keycloak)
# Use strong, unique passwords in production
POSTGRES_DB=keycloak
POSTGRES_USER=your-postgres-username
POSTGRES_PASSWORD=your-postgres-password

# ========================================
# NGINX PROXY CONFIGURATION
# ========================================
# Enable nginx reverse proxy (true) or direct service access (false)
NGINX_PROXY_MODE=true

# Enable SSL/HTTPS (requires certificates in Setup/Certificates/)
NGINX_SSL_ENABLED=false

# Nginx port configuration
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Performance tuning
NGINX_WORKER_PROCESSES=auto

# SSL certificate paths (only needed if NGINX_SSL_ENABLED=true)
# Place your certificate and key in Setup/Certificates/.
# Use a PEM-formatted certificate/key pair; the filename extension can be .pem, .crt, or .key.
# Examples: ./Setup/Certificates/cert.pem or ./Setup/Certificates/server.crt
#           ./Setup/Certificates/privkey.pem or ./Setup/Certificates/server.key
SSL_CERT_FILE=./Setup/Certificates/cert.pem
SSL_KEY_FILE=./Setup/Certificates/privkey.pem

# ========================================
# EXTERNAL INTEGRATIONS (Optional)
# ========================================
# FHIR Server Configuration
# Leave empty if not using FHIR integration
FHIR_SERVER_URL=
FHIR_USERNAME=your-fhir-username
FHIR_PASSWORD=your-fhir-password
ICD10_FILTER=

# ONKOSTAR Database Configuration
# Only required when OVIS_IMPORT_MODE=ONKOSTAR
ONKOSTAR_DB_HOST=your-onkostar-host
ONKOSTAR_DB_PORT=3306
ONKOSTAR_DB_USER=your-onkostar-username
ONKOSTAR_DB_PASSWORD=your-onkostar-password

# 3CT Database Configuration
# STUDY_SYSTEM needs to be either left blank or variants can be LMU or TUM
STUDY_SYSTEM=
DCT_DB_HOST=your-3ct-host
DCT_DB_PORT=3306
DCT_DB_USER=your-3ct-username
DCT_DB_PASSWORD=your-3ct-password
DCT_DB_NAME=your-3ct-database


# ========================================
# Site specific organization
# ========================================
#Information about the technical admin handing out technical access to users
PUBLIC_SITE_SPECIFIC_TECHNICAL_ADMIN_NAME="Max Mustermann"
PUBLIC_SITE_SPECIFIC_TECHNICAL_ADMIN_EMAIL="max.mustermann@musterhausen.com"
#Determines whether a useragreement document will be shown. User-Agreements can be customized in folder XYZ.
PUBLIC_SITE_SPECIFIC_SHOW_USERAGREEMENT=true
#Determines whether a imprint will be shown. Following information is needed for this imprint.
PUBLIC_SITE_SPECIFIC_SHOW_IMPRINT=true
#Ther person responsible for hosting OVIS - usually the director of the CCC
PUBLIC_SITE_SPECIFIC_IMPRINT_RESPONSIBLE_WEBHOST_ORGANIZATION="Comprehensive Cancer Center"
PUBLIC_SITE_SPECIFIC_IMPRINT_RESPONSIBLE_WEBHOST_PERSON="Dr. Max Muster"
PUBLIC_SITE_SPECIFIC_IMPRINT_RESPONSIBLE_WEBHOST_ADDRESS_STREET="Musterstraße 3"
PUBLIC_SITE_SPECIFIC_IMPRINT_RESPONSIBLE_WEBHOST_ADDRESS_AREA="12345 Musterhausen"
PUBLIC_SITE_SPECIFIC_IMPRINT_HOSPITAL_PASSUS="eine rechtsfähige Anstalt des öffentlichen Rechts"
#Information about the hospital and its medical director
PUBLIC_SITE_SPECIFIC_IMPRINT_RESPONSIBLE_HOSPITAL_DIRECTOR="Muster Director"
PUBLIC_SITE_SPECIFIC_IMPRINT_HOSPITAL_NAME="University Hospital"
PUBLIC_SITE_SPECIFIC_IMPRINT_ADDRESS_STREET="Musterstraße 1"
PUBLIC_SITE_SPECIFIC_IMPRINT_ADDRESS_AREA="12345 Musterhausen"
#Daten zum lokalen Datenschützer
PUBLIC_SITE_SPECIFIC_IMPRINT_DATA_PROTECTION_OFFICER_NAME="Datenschutzbeauftragter Max Mustermann"
PUBLIC_SITE_SPECIFIC_IMPRINT_DATA_PROTECTION_OFFICER_STREET="Datenschutzstraße 3"
PUBLIC_SITE_SPECIFIC_IMPRINT_DATA_PROTECTION_OFFICER_AREA="12345 Datenschutzhausen"
PUBLIC_SITE_SPECIFIC_IMPRINT_DATA_PROTECTION_OFFICER_EMAIL="data@protection.com"
#Language for Login Screen and new Users - Currently supported: "de" (German), "en" (English)
PUBLIC_SYSTEM_START_LANGUAGE="en"

# ========================================
# PREPROCESSOR OVERRIDES (Optional)
# ========================================
# The preprocessing stage can be customised without code changes by setting the following variables.
#
# IMPORTANT CONCEPT:
# - The preprocessor detects events (Rezidiv/Metastase/Progress/DFS etc.) by applying RULES to specific fields.
# - Each rule clearly states: data source + field + match type + values.
#
# Formats:
# - Lists should be JSON arrays (recommended): ["a","b"]
# - Match types: equals | prefix | contains | regex

# ---------- Global / patient status ----------
# Keywords that flag a patient as deceased (used against patient.vitalState)
OVIS_PREPROC_DECEASED_KEYWORDS=["verstorben","dead","deceased","not alive","gestorben"]

# ---------- Progress / DFS (pprogress.overallAssessment / "Gesamtbeurteilung") ----------
# Values that count as "Progression" for PFS/DFS variants
OVIS_RULE_PP_OVERALLASSESSMENT_PROGRESS_MATCH=equals
OVIS_RULE_PP_OVERALLASSESSMENT_PROGRESS_VALUES=["Progression","Divergentes Geschehen","Rezidiv"]

# Values that count as "Complete remission" to start DFS clock (if used)
OVIS_RULE_PP_OVERALLASSESSMENT_COMPLETE_REMISSION_MATCH=equals
OVIS_RULE_PP_OVERALLASSESSMENT_COMPLETE_REMISSION_VALUES=["Vollremission / Tumorfrei (complete remission)"]

# ---------- Rezidiv detection (pprogress) ----------
# 1) Overall assessment (Gesamtbeurteilung) -> Rezidiv
# UI definition: "startet mit Schlagwort Rezidiv"
OVIS_RULE_PP_OVERALLASSESSMENT_REZIDIV_MATCH=prefix
OVIS_RULE_PP_OVERALLASSESSMENT_REZIDIV_VALUES=["Rezidiv"]

# 2) Tumor status (Tumorstatus) -> Rezidiv
OVIS_RULE_PP_TUMORSTATE_REZIDIV_MATCH=prefix
OVIS_RULE_PP_TUMORSTATE_REZIDIV_VALUES=["Rezidiv"]

# 3) Lymph node status (Lymphknotenstatus) -> Rezidiv
# UI definition: values "Rezidiv" or "Neu"
OVIS_RULE_PP_LYMPHNODESTATE_REZIDIV_MATCH=equals
OVIS_RULE_PP_LYMPHNODESTATE_REZIDIV_VALUES=["Rezidiv","Neu"]

# 4) Biochemical recurrence flag -> Rezidiv
OVIS_RULE_PP_BIOCHEMRECURRENCE_REZIDIV_MATCH=equals
OVIS_RULE_PP_BIOCHEMRECURRENCE_REZIDIV_VALUES=["Ja"]

# ---------- Metastasis detection ----------
# Metastases are primarily read from mmetastasis (metastasisDate/occurrenceDate).
# Additionally, metastases can be derived from progress entries:
# UI definition: progress.metastasisState (F-Metastase) = "Neu" or "Rezidiv"
OVIS_RULE_PP_METASTASISSTATE_MET_MATCH=equals
OVIS_RULE_PP_METASTASISSTATE_MET_VALUES=["Neu","Rezidiv"]

# Metastasis table spread values that count as metastasis evidence
OVIS_PREPROC_METASTASIS_SPREAD_VALUES=["Neu","Rezidiv","Tumornachweis"]

# ---------- DFS start conditions from TNM / Therapy ----------
OVIS_PREPROC_RCLASS_SUCCESS=["R0"]
OVIS_PREPROC_LOCAL_RSTATE_SUCCESS=["R0"]

# ---------- Output labels / stratification ----------
OVIS_PREPROC_METASTASIS_STRAT_SYNCHRON="Synchrone Metastasierung"
OVIS_PREPROC_METASTASIS_STRAT_NONE="keine synchrone Metastasierung"

# ---------- Other preprocessing knobs ----------
OVIS_PREPROC_NULL_STUDY_PHASES=["NOPH","KA"]

# Therapy mappings (per category lists)
OVIS_PREPROC_PREV_THERAPY_SURGERY=["operation"]
OVIS_PREPROC_PREV_THERAPY_SYSTEMIC=["systemic"]
OVIS_PREPROC_PREV_THERAPY_RADIATION=["radiation"]

# Consultation mappings (per category lists)
OVIS_PREPROC_PREV_CONSULTATION_NUTRITION=["nutrition"]
OVIS_PREPROC_PREV_CONSULTATION_SOCIAL=["social"]
OVIS_PREPROC_PREV_CONSULTATION_PSYCHO=["psycho"]
OVIS_PREPROC_PREV_CONSULTATION_GENETIC=["genetic"]

# Tumorboard type regexes (per category). Strings compile as /pattern/i.
OVIS_PREPROC_TUMORBOARD_PATTERN_PRAE="prae|prä|pre"
OVIS_PREPROC_TUMORBOARD_PATTERN_POST=post
OVIS_PREPROC_TUMORBOARD_PATTERN_MTB=mtb

# ECOG status prefix (single value)
OVIS_PREPROC_ECOG_PREFIX=ECOG
# Distress type label (single value)
OVIS_PREPROC_DISTRESS_TYPE=distress
# List of positive distress values
OVIS_PREPROC_DISTRESS_POSITIVE_VALUES=["Positiv"]

# ---------- Legacy variables (deprecated; kept for backward compatibility) ----------
# These older variables are still supported, but new OVIS_RULE_* variables above are preferred.
OVIS_PREPROC_PROGRESS_LABELS=["Progression","Divergentes Geschehen","Rezidiv"]
OVIS_PREPROC_COMPLETE_REMISSION_LABELS=["Vollremission / Tumorfrei (complete remission)"]
OVIS_PREPROC_REZIDIV_PREFIXES=["Rezidiv"]
OVIS_PREPROC_REZIDIV_CANONICAL=Rezidiv
OVIS_PREPROC_REZIDIV_LYMPH_STATES=["Rezidiv","Neu"]
OVIS_PREPROC_METASTASIS_PREFIXES=["Rezidiv","Neu"]


# ========================================
# FRONTEND FEATURE TOGGLES (Optional)
# ========================================
# Menubar entries can be toggled individually. Defaults are true (visible).
# Example: set to false to hide an entry (e.g. PUBLIC_NAV_STUDY_ENABLED=false).
PUBLIC_NAV_PATIENT_COHORT_ENABLED=true
PUBLIC_NAV_PATIENT_SINGLE_ENABLED=true
