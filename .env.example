PUBLIC_NAV_THERAPY_SYSTEMIC_ENABLED=true
PUBLIC_NAV_THERAPY_RADIATION_ENABLED=true
PUBLIC_NAV_PROGRESS_ENABLED=true
PUBLIC_NAV_TUMORBOARD_ENABLED=true
PUBLIC_NAV_CONSULTATION_ENABLED=true
PUBLIC_NAV_STATUS_ENABLED=true
PUBLIC_NAV_SURVIVAL_ENABLED=true
PUBLIC_NAV_SUPPLEMENTARY_ENABLED=true
PUBLIC_NAV_MOLECULAR_ENABLED=true
PUBLIC_NAV_BIO_MATERIAL_ENABLED=true
PUBLIC_NAV_STUDY_ENABLED=false
PUBLIC_NAV_USER_MANAGEMENT_ENABLED=true
PUBLIC_NAV_LABEL_PATIENT_COHORT=
PUBLIC_NAV_LABEL_PATIENT_SINGLE=
PUBLIC_NAV_LABEL_DIAGNOSIS=
PUBLIC_NAV_LABEL_TNM=
PUBLIC_NAV_LABEL_THERAPY_GENERAL=
PUBLIC_NAV_LABEL_THERAPY_OPERATION=
PUBLIC_NAV_LABEL_THERAPY_SYSTEMIC=
PUBLIC_NAV_LABEL_THERAPY_RADIATION=
PUBLIC_NAV_LABEL_PROGRESS=
PUBLIC_NAV_LABEL_TUMORBOARD=
PUBLIC_NAV_LABEL_CONSULTATION=
PUBLIC_NAV_LABEL_STATUS=
PUBLIC_NAV_LABEL_SURVIVAL=
PUBLIC_NAV_LABEL_SUPPLEMENTARY=
PUBLIC_NAV_LABEL_MOLECULAR=
PUBLIC_NAV_LABEL_BIO_MATERIAL=
PUBLIC_NAV_LABEL_STUDY=
PUBLIC_NAV_LABEL_USER_MANAGEMENT=

# Quicktools allow custom buttons and labels. Semicolon or comma separate entries; use '\;' or '\,' to keep a literal delimiter.
# Gender buttons expect entries as Label|Value (third part optional BindId). Values listed in PUBLIC_QUICKTOOLS_GENDER_OTHER_EXCLUSIONS are excluded when the "other" button is used.
PUBLIC_QUICKTOOLS_GENDER_BUTTONS="M|m;W|w|f;Other|other"
PUBLIC_QUICKTOOLS_GENDER_OTHER_EXCLUSIONS="m;w"
# Certification buttons use key=value entries (Label|Value[|BindId]). Keys supported: primary, recurrence, center.
PUBLIC_QUICKTOOLS_CERT_CASES_POS="primary=Primary Case|Ja,recurrence=Recurrence Case|true,center=Center Case|Ja"
PUBLIC_QUICKTOOLS_CERT_CASES_NEG="primary=Primary Case|Nein,recurrence=Recurrence Case|false,center=Center Case|Nein"
PUBLIC_QUICKTOOLS_CERT_INTERNAL_LABEL="Meine Einrichtung|Meine Einrichtung"
